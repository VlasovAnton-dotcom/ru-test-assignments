## 3. Клиентская логика (script.js)

```javascript
document.getElementById('regForm').onsubmit = function(e) {
    e.preventDefault();

    const name = document.getElementById('name').value;
    const surname = document.getElementById('surname').value;
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirmPassword').value;
    const messageDiv = document.getElementById('message');

    // Простая валидация на клиенте
    if (!email.includes('@')) {
        messageDiv.className = 'alert alert-danger';
        messageDiv.textContent = 'Email должен содержать @';
        messageDiv.style.display = 'block';
        return;
    }
    if (password !== confirmPassword) {
        messageDiv.className = 'alert alert-danger';
        messageDiv.textContent = 'Пароли не совпадают';
        messageDiv.style.display = 'block';
        return;
    }

    // AJAX-запрос
    const xhr = new XMLHttpRequest();
    xhr.open('POST', 'process.php', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onreadystatechange = function() {
        if (xhr.readyState === 4 && xhr.status === 200) {
            const response = JSON.parse(xhr.responseText);
            if (response.success) {
                document.getElementById('regForm').style.display = 'none';
                messageDiv.className = 'alert alert-success';
                messageDiv.textContent = response.message;
                messageDiv.style.display = 'block';
            } else {
                messageDiv.className = 'alert alert-danger';
                messageDiv.textContent = response.message;
                messageDiv.style.display = 'block';
            }
        }
    };
    xhr.send(`name=${name}&surname=${surname}&email=${email}&password=${password}`);
};
```

## 4. Обработчик на PHP (process.php)

```php
<?php
header('Content-Type: application/json');

// Получаем данные
$name = $_POST['name'] ?? '';
$surname = $_POST['surname'] ?? '';
$email = $_POST['email'] ?? '';
$password = $_POST['password'] ?? '';
$confirmPassword = $_POST['confirmPassword'] ?? '';

// Валидация
if (strpos($email, '@') === false) {
    echo json_encode(['success' => false, 'message' => 'Некорректный email']);
    exit;
}
if ($password !== $confirmPassword) {
    echo json_encode(['success' => false, 'message' => 'Пароли не совпадают']);
    exit;
}

// Подключаем массив пользователей (имитация БД)
require_once 'users.php';

// Проверка на существование email
$emailExists = false;
foreach ($users as $user) {
    if ($user['email'] === $email) {
        $emailExists = true;
        break;
    }
}

// Логирование результата проверки
$logMessage = date('Y-m-d H:i:s') . " | Email: $email | " . ($emailExists ? 'Уже существует' : 'Свободен') . "\n";
file_put_contents(__DIR__ . '/logs/registration.log', $logMessage, FILE_APPEND);

// Ответ клиенту
if ($emailExists) {
    echo json_encode(['success' => false, 'message' => 'Пользователь с таким email уже зарегистрирован']);
} else {
    echo json_encode(['success' => true, 'message' => 'Регистрация прошла успешно!']);
}
?>
```

