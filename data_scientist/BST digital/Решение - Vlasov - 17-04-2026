```python
# Расчёт оптимального склада для слов из первого четверостишья Пушкина
# Условия:
# - прибыль за собранное слово: 40 руб.
# - неустойка, если слово не собрать: 10 руб.
# - экспресс-доставка недостающей буквы: 2 руб. (только если не хватает ровно одной буквы)
# - хранение буквы: 1 руб. в день
# - в конце дня склад обновляется (поэтому хранение — просто сумма количеств букв)
# - регистр и знаки препинания не важны

from collections import Counter, defaultdict

poem_line = "Во глубине сибирских руд Храните гордое терпенье, Не пропадет ваш скорбный труд И дум высокое стремленье."

# Нормализация: нижний регистр, только буквы, слова через пробел
import re
words = [w for w in re.sub(r'[^a-zа-яё ]', '', poem_line.lower()).split() if w]

# Частоты букв по всем словам (для оценки "стоимости" склада)
letter_freq = Counter()
for w in words:
    letter_freq.update(w)

# Функция прибыли для заданного склада (dict: буква -> количество)

def profit_for_stock(stock):
    total = 0.0
    for w in words:
        need = Counter(w)
        # сколько букв не хватает по складу
        missing = sum(max(0, need[ch] - stock.get(ch, 0)) for ch in need)
        if missing == 0:
            total += 40.0
        elif missing == 1:
            total += 40.0 - 2.0  # доставим одну букву
        else:
            total -= 10.0  # неустойка
    return total

# Оценка стоимости хранения: сумма количеств букв на складе (по 1 рублю за букву)

def storage_cost(stock):
    return sum(stock.values())

# Прибыль минус хранение (дневная чистая прибыль)

def net_profit(stock):
    return profit_for_stock(stock) - storage_cost(stock)

# Стратегия A: держать на складе по максимуму встречаемости каждой буквы среди всех слов (это минимизирует неустойку и экспресс-доставку)
stock_A = dict(letter_freq)
net_A = net_profit(stock_A)
profit_A = profit_for_stock(stock_A)
cost_A = storage_cost(stock_A)

# Стратегия B: держать ровно по одной каждой букве, встречающейся в словах (дешёвый склад, много неустоек/экспресс-доставки)
unique_letters = set(''.join(words))
stock_B = {ch: 1 for ch in unique_letters}
net_B = net_profit(stock_B)
profit_B = profit_for_stock(stock_B)
cost_B = storage_cost(stock_B)

# Стратегия C: держать только те буквы, которые встречаются более чем в половине слов (эксперимент)
total_words = len(words)
letter_in_word_count = defaultdict(int)
for w in words:
    for ch in set(w):
        letter_in_word_count[ch] += 1
stock_C = {ch: letter_freq[ch] for ch in letter_freq if letter_in_word_count[ch] > total_words/2}
net_C = net_profit(stock_C)
profit_C = profit_for_stock(stock_C)
cost_C = storage_cost(stock_C)

# Выберем лучший вариант по чистой прибыли
candidates = [
    (net_A, stock_A, 'A'),
    (net_B, stock_B, 'B'),
    (net_C, stock_C, 'C')
]
best_net, best_stock, best_tag = max(candidates, key=lambda x: x[0])

print("Стратегия A (максимальные частоты):\n", stock_A)
print(f"Чистая прибыль: {net_A:.2f} руб/день; валовая прибыль: {profit_A:.2f}; хранение: {cost_A}\n")
print("Стратегия B (по одной букве):\n", stock_B)
print(f"Чистая прибыль: {net_B:.2f} руб/день; валовая прибыль: {profit_B:.2f}; хранение: {cost_B}\n")
print("Стратегия C (частые буквы):\n", stock_C)
print(f"Чистая прибыль: {net_C:.2f} руб/день; валовая прибыль: {profit_C:.2f}; хранение: {cost_C}\n")
print(f"Лучший вариант: стратегия {best_tag}\nСклад:\n", best_stock)
print(f"Средняя дневная чистая прибыль: {best_net:.2f} руб/день")
```
## Оптимальный набор букв на складе и средняя дневная прибыль

Для максимизации прибыли при выполнении заказов на слова из первого четверостишья Пушкина рекомендуется держать на складе следующий запас букв:

```python
{
